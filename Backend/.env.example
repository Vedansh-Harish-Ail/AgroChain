# AgroChain Flask Backend Environment Variables
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# Security Keys
SECRET_KEY=agrochain-super-secret-key-1234
JWT_SECRET_KEY=jwt-agrochain-secret-key-5678

# Database Connection URI
# SQLite Default:
DATABASE_URL=sqlite:///agrochain.db

# PostgreSQL (Replace with your credentials if using PostgreSQL):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agrochain
